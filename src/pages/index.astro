---
// src/pages/index.astro
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/global.css';

// Import data JSON
import poetsData from '../data/poets.json';
import poemsData from '../data/poems.json';
import quizData from '../data/quiz.json';
import glossaryData from '../data/glossary.json';

const poets = poetsData.poets;
const poems = poemsData.poems;
const quiz = quizData.quiz;
const glossary = glossaryData.glossary;
---

<MainLayout>
  <!-- ============================================================
       TOP NAVIGATION BAR (fixed)
       ============================================================ -->
  <nav id="top-nav" class="fixed top-0 left-0 right-0 z-50 glass-dark border-b border-gold-500/10 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between gap-4">
      <!-- Logo -->
      <button id="btn-go-home" class="flex items-center gap-2 group" aria-label="Kembali ke halaman utama">
        <span class="text-gold-500 text-xl animate-float">✦</span>
        <span class="font-serif font-bold text-sm text-cream-100 group-hover:text-gold-400 transition-colors hidden sm:block">Petualangan Puisi</span>
      </button>

      <!-- Progress bar (hidden on splash) -->
      <div id="nav-progress" class="flex-1 max-w-xs hidden">
        <div class="flex items-center gap-2">
          <span class="text-xs text-gold-400 font-semibold whitespace-nowrap" id="nav-progress-label">Misi 0/5</span>
          <div class="flex-1 h-1.5 bg-navy-800 rounded-full overflow-hidden">
            <div id="nav-progress-bar" class="progress-bar-fill h-full rounded-full w-0"></div>
          </div>
        </div>
      </div>

      <!-- Nav buttons -->
      <div class="flex items-center gap-2">
        <button id="btn-open-glossary" class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-gold-400 hover:bg-gold-500/10 transition-colors" aria-label="Glosarium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Glosarium
        </button>
        <button id="btn-open-menu" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-cream-100 hover:bg-navy-700 transition-colors" aria-label="Menu">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          Menu
        </button>
      </div>
    </div>
  </nav>

  <!-- ============================================================
       MENU SIDEBAR (Kata Pengantar, Daftar Isi, Penulis, dll)
       ============================================================ -->
  <div id="nav-overlay" class="nav-overlay" role="presentation"></div>
  <aside id="menu-sidebar" class="sidebar-drawer glass-dark" role="dialog" aria-label="Menu Utama">
    <div class="p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-serif font-bold text-xl text-gradient">Menu Buku</h2>
        <button id="btn-close-menu" class="p-2 rounded-lg hover:bg-navy-700 transition-colors" aria-label="Tutup menu">
          <svg class="w-5 h-5 text-cream-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      
      <!-- Menu items -->
      <nav class="space-y-2">
        {[
          { id: 'menu-pengantar', icon: '📜', label: 'Kata Pengantar', section: 'pengantar' },
          { id: 'menu-daftar-isi', icon: '📋', label: 'Daftar Isi', section: 'daftar-isi' },
          { id: 'menu-misi-map', icon: '🗺️', label: 'Peta Misi', section: 'mission-map' },
          { id: 'menu-glossary-2', icon: '📚', label: 'Glosarium', section: 'glossary' },
          { id: 'menu-bibliography', icon: '🔖', label: 'Daftar Pustaka', section: 'bibliography' },
          { id: 'menu-author', icon: '✍️', label: 'Biografi Penulis', section: 'author' },
        ].map(item => (
          <button 
            class="menu-nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left text-cream-100 hover:bg-navy-700 hover:text-gold-400 transition-all group"
            data-section={item.section}
            id={item.id}
          >
            <span class="text-xl">{item.icon}</span>
            <span class="font-medium">{item.label}</span>
            <svg class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        ))}
      </nav>

      <div class="mt-8 pt-6 border-t border-navy-700">
        <div class="ornament mb-4">
          <span class="text-xs text-gold-400/60 font-medium">INFO</span>
        </div>
        <p class="text-xs text-cream-100/50 leading-relaxed">
          Sesuai Permendikbud No. 8 Tahun 2016 tentang Buku yang Digunakan oleh Satuan Pendidikan.
        </p>
      </div>
    </div>
  </aside>

  <!-- ============================================================
       MAIN CONTENT AREA — Multi-section SPA
       ============================================================ -->
  <main id="app-main" class="min-h-screen pt-14">

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: SPLASH SCREEN / HALAMAN SAMPUL
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-splash" class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden stars-bg px-4 py-16">
      <!-- Background radial glow -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-96 h-96 bg-gold-500/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-indigo-500/5 rounded-full blur-3xl"></div>
      </div>

      <!-- Book cover card -->
      <div class="relative z-10 glass rounded-2xl p-8 sm:p-12 max-w-lg w-full text-center shadow-2xl">
        <!-- Decorative badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gold-500/10 border border-gold-500/30 mb-6">
          <span class="text-gold-400 text-xs font-semibold tracking-widest uppercase">Bahan Pengayaan</span>
        </div>

        <!-- Ornament top -->
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="h-px w-12 bg-gradient-to-r from-transparent to-gold-500/50"></div>
          <span class="text-gold-500 text-lg">✦</span>
          <div class="h-px w-12 bg-gradient-to-l from-transparent to-gold-500/50"></div>
        </div>

        <!-- Judul -->
        <h1 class="font-serif font-black text-4xl sm:text-5xl text-gradient leading-tight mb-3">
          Petualangan<br />Puisi Nusantara
        </h1>
        <p class="font-serif italic text-cream-200/70 text-lg mb-2">Menjelajahi Keindahan Kata-Kata</p>

        <!-- Divider -->
        <div class="ornament my-5">
          <span class="text-gold-500/40 text-sm">❧</span>
        </div>

        <!-- Peruntukan -->
        <div class="flex items-center justify-center gap-2 mb-3">
          <svg class="w-4 h-4 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zM12 14v7"/></svg>
          <span class="text-cream-200/60 text-sm">Pengayaan Bahasa Indonesia SMA</span>
        </div>

        <!-- Nama penulis -->
        <div class="mb-8">
          <p class="text-cream-200/40 text-xs uppercase tracking-widest mb-1">Disusun oleh</p>
          <p class="font-serif text-xl text-gold-300 font-semibold">Tim Pengembang Modul</p>
        </div>

        <!-- CTA Button -->
        <button id="btn-mulai" class="btn-gold w-full px-8 py-4 rounded-xl font-bold text-navy-950 text-lg flex items-center justify-center gap-3 shadow-lg animate-pulse-gold" aria-label="Mulai petualangan belajar puisi">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Mulai Petualangan
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>

        <p class="text-cream-100/30 text-xs mt-4">✦ Tap untuk membuka petunjuk penggunaan</p>
      </div>

      <!-- Floating poetry quote -->
      <div class="relative z-10 mt-8 max-w-md text-center animate-float" style="animation-delay: 1s">
        <p class="font-serif italic text-cream-200/40 text-sm">"Sekali berarti, sesudah itu mati."</p>
        <p class="text-gold-500/30 text-xs mt-1">— Chairil Anwar</p>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: KATA PENGANTAR
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-pengantar" class="hidden min-h-screen px-4 py-16 max-w-3xl mx-auto">
      <div class="reveal">
        <button class="btn-back flex items-center gap-2 text-gold-400 hover:text-gold-300 transition-colors mb-8 text-sm" data-target="mission-map">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Kembali
        </button>
        
        <div class="ornament mb-6"><span class="text-gold-400 font-serif italic text-sm">Kata Pengantar</span></div>
        
        <h2 class="font-serif font-bold text-3xl text-gradient mb-8">Salam dari Penulis</h2>

        <div class="glass rounded-2xl p-6 sm:p-8 space-y-5 prose-poetry text-cream-200/80 leading-relaxed">
          <p>Puji syukur kehadirat Tuhan Yang Maha Esa atas terselesaikannya modul pengayaan interaktif ini. Modul ini hadir sebagai jembatan antara dunia sastra klasik dan generasi digital yang penuh semangat.</p>
          
          <p>Buku pengayaan ini dirancang khusus untuk peserta didik SMA yang ingin memperdalam pemahaman tentang puisi Indonesia — bukan sekadar menghafal, melainkan merasakan, menikmati, dan menciptakan.</p>
          
          <div class="glass-dark rounded-xl p-4 border-l-4 border-gold-500">
            <p class="text-gold-300 font-serif italic text-base">"Puisi adalah bahasa yang paling jujur — ia lahir dari sudut hati yang paling dalam, dan sampai ke jiwa pembaca tanpa perlu diterjemahkan."</p>
          </div>

          <p>Melalui pendekatan <em>gamified learning</em>, peserta didik akan menjalani lima misi yang dirancang secara progresif: dari memahami konsep dasar puisi, menjelajahi karya-karya monumental, menganalisis unsur intrinsik, berkarya sendiri, hingga merefleksikan pembelajaran.</p>

          <p>Modul ini disusun berdasarkan amanat <strong>Permendikbud Nomor 8 Tahun 2016</strong> tentang Buku yang Digunakan oleh Satuan Pendidikan, dan mengacu pada Capaian Pembelajaran Bahasa Indonesia SMA Fase F.</p>

          <p>Semoga petualangan puisi ini menjadi pengalaman yang berkesan dan menginspirasi.</p>

          <div class="text-right mt-6">
            <p class="text-cream-200/60 text-sm">Hormat kami,</p>
            <p class="font-serif font-bold text-gold-300 text-xl mt-1">Tim Pengembang Modul</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: DAFTAR ISI
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-daftar-isi" class="hidden min-h-screen px-4 py-16 max-w-3xl mx-auto">
      <div class="reveal">
        <button class="btn-back flex items-center gap-2 text-gold-400 hover:text-gold-300 transition-colors mb-8 text-sm" data-target="mission-map">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Kembali
        </button>

        <div class="ornament mb-6"><span class="text-gold-400 font-serif italic text-sm">Daftar Isi</span></div>
        <h2 class="font-serif font-bold text-3xl text-gradient mb-8">Peta Konten Buku</h2>

        <div class="space-y-3">
          {[
            { num: '✦', label: 'Kata Pengantar', page: 'ii', section: 'pengantar', locked: false },
            { num: '01', label: 'Misi 1 — Pendahuluan & Tujuan Pembelajaran', page: '1', section: 'mission-1', locked: false },
            { num: '02', label: 'Misi 2 — Buku Puisi & Biografi Penyair', page: '8', section: 'mission-2', locked: false },
            { num: '03', label: 'Misi 3 — Bait Puisi & Analisis Unsur Intrinsik', page: '22', section: 'mission-3', locked: false },
            { num: '04', label: 'Misi 4 — Ruang Berkarya (Menulis Puisi)', page: '40', section: 'mission-4', locked: false },
            { num: '05', label: 'Misi 5 — Refleksi & Evaluasi Diri', page: '52', section: 'mission-5', locked: false },
            { num: '✧', label: 'Penutup & Apresiasi', page: '60', section: 'closing', locked: false },
            { num: '◈', label: 'Glosarium', page: '64', section: 'glossary', locked: false },
            { num: '◈', label: 'Daftar Pustaka', page: '68', section: 'bibliography', locked: false },
            { num: '◈', label: 'Biografi Penulis', page: '70', section: 'author', locked: false },
          ].map((item, i) => (
            <button 
              class="daftar-isi-btn w-full glass rounded-xl px-5 py-3.5 flex items-center gap-4 text-left hover:bg-navy-700/50 hover:border-gold-500/30 transition-all group"
              data-section={item.section}
            >
              <span class="font-serif text-gold-500 font-bold text-sm w-8 shrink-0 text-center">{item.num}</span>
              <span class="flex-1 text-cream-100 text-sm font-medium group-hover:text-gold-300 transition-colors">{item.label}</span>
              <span class="text-cream-100/30 text-xs font-mono">hlm. {item.page}</span>
              <svg class="w-4 h-4 text-gold-400 opacity-0 group-hover:opacity-100 transition-opacity shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: PETA MISI UTAMA
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-mission-map" class="hidden min-h-screen px-4 py-12">
      <div class="max-w-4xl mx-auto">
        <div class="reveal text-center mb-10">
          <div class="ornament mb-4"><span class="text-gold-400 font-serif italic text-sm">Peta Perjalanan</span></div>
          <h2 class="font-serif font-black text-4xl text-gradient mb-3">Linimasa Misi</h2>
          <p class="text-cream-100/50 text-sm">Selesaikan setiap misi untuk membuka misi berikutnya</p>
          
          <!-- Overall progress -->
          <div class="mt-6 glass rounded-xl px-6 py-4 inline-flex flex-col items-center gap-2 min-w-60">
            <span class="text-xs text-gold-400/70 uppercase tracking-widest font-medium">Progres Keseluruhan</span>
            <div class="w-full h-2 bg-navy-800 rounded-full overflow-hidden">
              <div id="overall-progress-bar" class="progress-bar-fill h-full rounded-full w-0"></div>
            </div>
            <span id="overall-progress-text" class="text-gold-400 font-bold text-sm">0 / 5 Misi Selesai</span>
          </div>
        </div>

        <!-- Mission Cards Grid -->
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="mission-cards-grid">
          {[
            {
              num: 1, id: 'mission-1', emoji: '📖', color: 'from-amber-900/40 to-amber-800/20',
              accentColor: '#f59e0b', borderColor: 'border-amber-500/30',
              title: 'Pendahuluan', subtitle: 'Mengenal Dunia Puisi',
              desc: 'Pengantar materi pengayaan puisi dan tujuan pembelajaran yang estetik.',
              xp: '100 XP', dur: '~10 menit',
            },
            {
              num: 2, id: 'mission-2', emoji: '🧭', color: 'from-indigo-900/40 to-indigo-800/20',
              accentColor: '#6366f1', borderColor: 'border-indigo-500/30',
              title: 'Buku Puisi & Penyair', subtitle: 'Tokoh Legendaris Nusantara',
              desc: 'Eksplorasi interaktif kumpulan buku puisi terkenal dan biografi penyair.',
              xp: '150 XP', dur: '~15 menit',
            },
            {
              num: 3, id: 'mission-3', emoji: '🔍', color: 'from-violet-900/40 to-violet-800/20',
              accentColor: '#8b5cf6', borderColor: 'border-violet-500/30',
              title: 'Bait Puisi & Analisis', subtitle: 'Membedah Unsur Intrinsik',
              desc: 'Klik kata-kata puisi untuk mengungkap analisis mendalam unsur intrinsiknya.',
              xp: '200 XP', dur: '~20 menit',
            },
            {
              num: 4, id: 'mission-4', emoji: '✍️', color: 'from-emerald-900/40 to-emerald-800/20',
              accentColor: '#10b981', borderColor: 'border-emerald-500/30',
              title: 'Ruang Berkarya', subtitle: 'Menulis Puisimu Sendiri',
              desc: 'Tuangkan kreativitasmu! Tulis, simpan, dan unduh puisi karyamu sendiri.',
              xp: '250 XP', dur: '~25 menit',
            },
            {
              num: 5, id: 'mission-5', emoji: '⚔️', color: 'from-rose-900/40 to-rose-800/20',
              accentColor: '#ef4444', borderColor: 'border-rose-500/30',
              title: 'Refleksi Diri', subtitle: 'Evaluasi Pemahaman',
              desc: 'Kuis 5 soal pilihan ganda dengan health bar. Buktikan pengetahuanmu!',
              xp: '300 XP', dur: '~15 menit',
            },
            {
              num: 6, id: 'closing', emoji: '🏆', color: 'from-gold-900/40 to-gold-800/20',
              accentColor: '#f59e0b', borderColor: 'border-gold-500/30',
              title: 'Penutup', subtitle: 'Apresiasi & Kesimpulan',
              desc: 'Selamat! Raih sertifikat penyelesaian dan nikmati apresiasi atas perjalananmu.',
              xp: '★★★', dur: 'Final',
            },
          ].map((m) => (
            <div 
              id={`mission-card-${m.num}`}
              class={`mission-card glass rounded-2xl p-5 bg-gradient-to-br ${m.color} border ${m.borderColor} card-hover cursor-pointer relative overflow-hidden`}
              data-mission={m.num}
              data-section={m.id}
            >
              <!-- Lock overlay (injected via JS) -->
              <div class="mission-lock-overlay hidden absolute inset-0 bg-navy-950/70 rounded-2xl backdrop-blur-sm flex flex-col items-center justify-center z-10">
                <svg class="w-8 h-8 text-cream-100/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <p class="text-cream-100/30 text-xs mt-2">Selesaikan misi sebelumnya</p>
              </div>

              <!-- Completed badge -->
              <div class="mission-done-badge hidden absolute top-3 right-3 z-10">
                <span class="flex items-center gap-1 px-2 py-1 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-xs font-bold">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Selesai
                </span>
              </div>

              <!-- Card content -->
              <div class="flex items-start gap-3 mb-3">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style={`background: ${m.accentColor}18; border: 1px solid ${m.accentColor}30`}>
                  {m.emoji}
                </div>
                <div>
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-mono font-bold" style={`color: ${m.accentColor}`}>MISI {m.num < 6 ? m.num : '★'}</span>
                  </div>
                  <h3 class="font-serif font-bold text-base text-cream-100 leading-tight">{m.title}</h3>
                  <p class="text-xs text-cream-100/50">{m.subtitle}</p>
                </div>
              </div>

              <p class="text-cream-100/60 text-xs leading-relaxed mb-4">{m.desc}</p>

              <div class="flex items-center justify-between">

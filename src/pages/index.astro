          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Peta Misi
        </button>

        <div class="glass rounded-2xl p-6 sm:p-8 mb-8 bg-gradient-to-br from-emerald-900/30 to-emerald-800/10 border border-emerald-500/20">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center text-2xl">✍️</div>
            <div>
              <p class="text-emerald-400 text-xs font-bold tracking-widest uppercase">Misi 04</p>
              <h2 class="font-serif font-black text-3xl text-gradient">Ruang Berkarya</h2>
            </div>
          </div>
          <p class="text-cream-100/70 text-sm">Saatnya kamu menjadi penyair! Tulis puisimu di sini. Karyamu akan tersimpan otomatis dan bisa diunduh atau disalin untuk dikumpulkan ke guru.</p>
        </div>

        <!-- Writing guidelines -->
        <div class="grid sm:grid-cols-3 gap-3 mb-6">
          {[
            { emoji: '💡', tip: 'Pilih satu tema yang kamu rasakan: alam, cinta, perjuangan, atau keseharian.' },
            { emoji: '🎨', tip: 'Gunakan minimal 1 majas: metafora, personifikasi, atau simile.' },
            { emoji: '🎵', tip: 'Perhatikan irama. Coba baca pelan-pelan dan rasakan musikalitasnya.' },
          ].map(t => (
            <div class="glass rounded-xl p-4 text-xs text-cream-100/60 leading-relaxed flex gap-3">
              <span class="text-xl">{t.emoji}</span>
              <span>{t.tip}</span>
            </div>
          ))}
        </div>

        <!-- Poem info fields -->
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="text-xs text-cream-100/50 uppercase tracking-wide mb-1.5 block">Judul Puisi</label>
            <input 
              id="poem-title-input"
              type="text"
              placeholder="Masukkan judul puisimu..."
              class="w-full px-4 py-3 rounded-xl poetry-textarea text-base"
              style="resize: none; min-height: auto; line-height: 1.5; font-family: var(--font-serif);"
            />
          </div>
          <div>
            <label class="text-xs text-cream-100/50 uppercase tracking-wide mb-1.5 block">Nama Penyair (Kamu!)</label>
            <input 
              id="poem-author-input"
              type="text"
              placeholder="Nama lengkapmu..."
              class="w-full px-4 py-3 rounded-xl poetry-textarea text-base"
              style="resize: none; min-height: auto; line-height: 1.5; font-family: var(--font-serif);"
            />
          </div>
        </div>

        <!-- Main textarea -->
        <div class="relative mb-4">
          <label class="text-xs text-cream-100/50 uppercase tracking-wide mb-1.5 block">Isi Puisi</label>
          <textarea 
            id="poem-content-textarea"
            rows="12"
            placeholder="Tulis puisimu di sini...

Contoh awal baris:
Di tepi waktu yang terlupakan,
Aku berdiri mencari bayangan—"
            class="w-full px-5 py-4 rounded-xl poetry-textarea"
          ></textarea>
          <div class="absolute bottom-3 right-3 text-xs text-cream-100/20 font-mono" id="word-counter">0 kata</div>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-3 mb-8">
          <button id="btn-save-poem" class="flex items-center gap-2 px-5 py-3 rounded-xl bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-sm font-medium hover:bg-emerald-500/30 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/></svg>
            Simpan Draft
          </button>
          <button id="btn-copy-poem" class="flex items-center gap-2 px-5 py-3 rounded-xl glass border border-navy-600 text-cream-100/70 text-sm font-medium hover:border-gold-500/30 hover:text-gold-400 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            Salin Puisi
          </button>
          <button id="btn-download-poem" class="flex items-center gap-2 px-5 py-3 rounded-xl glass border border-navy-600 text-cream-100/70 text-sm font-medium hover:border-gold-500/30 hover:text-gold-400 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Unduh PDF
          </button>
          <button id="btn-clear-poem" class="flex items-center gap-2 px-5 py-3 rounded-xl glass border border-rose-500/20 text-rose-400/70 text-sm font-medium hover:bg-rose-500/10 hover:border-rose-500/30 transition-all ml-auto">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Hapus
          </button>
        </div>

        <div id="save-status" class="hidden mb-4 px-4 py-3 rounded-xl bg-emerald-500/15 border border-emerald-500/30 text-emerald-400 text-sm flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Puisi tersimpan di perangkatmu!
        </div>

        <!-- CTA -->
        <div class="text-center py-4">
          <button id="btn-complete-mission-4" class="btn-gold px-8 py-4 rounded-xl font-bold text-navy-950 text-base inline-flex items-center gap-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            Selesaikan Misi 4 & Lanjut ke Misi 5
          </button>
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: MISI 5 — KUIS EVALUASI DIRI
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-mission-5" class="hidden min-h-screen px-4 py-12 max-w-3xl mx-auto">
      <div class="reveal">
        <button class="btn-back flex items-center gap-2 text-gold-400 hover:text-gold-300 transition-colors mb-8 text-sm" data-target="mission-map">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Peta Misi
        </button>

        <div class="glass rounded-2xl p-6 sm:p-8 mb-6 bg-gradient-to-br from-rose-900/30 to-rose-800/10 border border-rose-500/20">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-rose-500/20 border border-rose-500/30 flex items-center justify-center text-2xl">⚔️</div>
            <div>
              <p class="text-rose-400 text-xs font-bold tracking-widest uppercase">Misi Final 05</p>
              <h2 class="font-serif font-black text-3xl text-gradient">Refleksi Diri</h2>
            </div>
          </div>
          <p class="text-cream-100/70 text-sm">{quiz.description}</p>
        </div>

        <!-- Health Bar (quiz mode) -->
        <div class="glass rounded-2xl p-5 mb-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-bold text-cream-100 flex items-center gap-2">
              <span>❤️</span> Health Bar
            </span>
            <span id="quiz-score-display" class="text-gold-400 font-bold text-sm">0 / 0 poin</span>
          </div>
          <div class="h-4 bg-navy-800 rounded-full overflow-hidden border border-navy-700">
            <div id="health-bar" class="health-bar-fill h-full rounded-full w-full transition-all duration-700"></div>
          </div>
          <div class="flex justify-between mt-1">
            <span class="text-xs text-cream-100/30" id="quiz-q-counter">Soal 0 dari {quiz.questions.length}</span>
            <span class="text-xs text-cream-100/30" id="quiz-hp-label">100 HP</span>
          </div>
        </div>

        <!-- Quiz container -->
        <div id="quiz-container">
          <!-- Question cards injected by JS -->
          {quiz.questions.map((q, qi) => (
            <div id={`q-card-${q.id}`} class={`quiz-question-card ${qi !== 0 ? 'hidden' : ''}`}>
              <div class="glass rounded-2xl p-6 mb-4">
                <div class="flex items-center gap-2 mb-4">
                  <span class="px-2.5 py-1 rounded-full bg-rose-500/20 text-rose-400 text-xs font-bold">Soal {q.id}</span>
                  <div class="flex-1 h-1 bg-navy-700 rounded-full overflow-hidden">
                    <div class="h-full bg-rose-500/50 rounded-full" style={`width: ${(q.id / quiz.questions.length) * 100}%`}></div>
                  </div>
                </div>
                
                <h3 class="font-serif text-lg text-cream-100 leading-relaxed mb-5">{q.question}</h3>
                
                <div class="space-y-2" id={`options-${q.id}`}>
                  {q.options.map((opt, oi) => (
                    <button 
                      class={`quiz-option w-full text-left px-4 py-3 rounded-xl glass text-sm text-cream-100/80`}
                      data-q={q.id}
                      data-opt={oi}
                      data-correct={q.correct}
                    >
                      <span class="inline-flex items-center gap-3">
                        <span class="w-6 h-6 rounded-full border border-current flex items-center justify-center text-xs font-bold shrink-0 text-gold-400/60">
                          {String.fromCharCode(65 + oi)}
                        </span>
                        {opt}
                      </span>
                    </button>
                  ))}
                </div>

                <div id={`explanation-${q.id}`} class="hidden mt-4 p-4 rounded-xl bg-navy-800/60 border border-navy-600">
                  <p class="text-xs text-cream-100/60 leading-relaxed">{q.explanation}</p>
                </div>

                <div class="flex justify-end mt-4">
                  <button 
                    id={`btn-next-q-${q.id}`}
                    class="hidden btn-gold px-5 py-2.5 rounded-xl text-navy-950 text-sm font-bold"
                    data-current={q.id}
                    data-next={q.id + 1}
                    data-total={quiz.questions.length}
                  >
                    {qi < quiz.questions.length - 1 ? 'Soal Berikutnya →' : 'Lihat Hasil 🏆'}
                  </button>
                </div>
              </div>
            </div>
          ))}

          <!-- Quiz Result Panel -->
          <div id="quiz-result" class="hidden">
            <div class="glass rounded-2xl p-8 text-center">
              <div class="text-6xl mb-4" id="result-emoji">🏆</div>
              <h3 class="font-serif font-black text-3xl text-gradient mb-2" id="result-title">Luar Biasa!</h3>
              <p class="text-cream-100/60 mb-6" id="result-message">Kamu telah menyelesaikan kuis dengan sempurna!</p>
              
              <div class="glass-dark rounded-2xl p-5 mb-6 inline-block min-w-48">
                <p class="text-cream-100/40 text-xs uppercase tracking-widest mb-1">Skor Final</p>
                <p class="font-serif font-black text-5xl text-gradient" id="result-score">0</p>
                <p class="text-cream-100/40 text-xs mt-1" id="result-maxscore">dari 100 poin</p>
              </div>
              
              <div class="flex flex-wrap justify-center gap-3 mb-6">
                <button id="btn-retry-quiz" class="flex items-center gap-2 px-5 py-2.5 rounded-xl glass border border-navy-600 text-cream-100/70 text-sm font-medium hover:border-gold-500/30 hover:text-gold-400 transition-all">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  Ulangi Kuis
                </button>
                <button id="btn-complete-mission-5" class="btn-gold px-5 py-2.5 rounded-xl font-bold text-navy-950 text-sm inline-flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  Selesaikan & Lihat Penutup
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: CLOSING / PENUTUP
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-closing" class="hidden min-h-screen px-4 py-16 max-w-3xl mx-auto">
      <div class="reveal text-center">
        <div class="inline-flex flex-col items-center mb-8">
          <div class="text-8xl mb-4 animate-float">🏆</div>
          <div class="ornament mb-4 w-full"><span class="text-gold-400 font-serif italic">Selamat!</span></div>
          <h2 class="font-serif font-black text-4xl sm:text-5xl text-gradient leading-tight mb-4">
            Petualangan<br />Selesai!
          </h2>
          <p class="text-cream-100/60 leading-relaxed max-w-md">
            Kamu telah menyelesaikan seluruh misi dalam modul pengayaan puisi ini. Luar biasa! Sekarang kamu bukan hanya pembaca puisi — kamu adalah penjelajah kata sejati.
          </p>
        </div>

        <!-- Achievement badges -->
        <div class="grid grid-cols-3 sm:grid-cols-5 gap-3 mb-8">
          {[
            { emoji: '📖', label: 'Pengenal', color: '#f59e0b' },
            { emoji: '🧭', label: 'Penjelajah', color: '#6366f1' },
            { emoji: '🔍', label: 'Analis', color: '#8b5cf6' },
            { emoji: '✍️', label: 'Penyair', color: '#10b981' },
            { emoji: '⚔️', label: 'Pejuang', color: '#ef4444' },
          ].map(b => (
            <div class="glass rounded-xl p-3 flex flex-col items-center gap-1.5">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-xl" style={`background: ${b.color}20; border: 2px solid ${b.color}40`}>
                {b.emoji}
              </div>
              <span class="text-xs text-cream-100/50 font-medium">{b.label}</span>
            </div>
          ))}
        </div>

        <!-- Kesimpulan -->
        <div class="glass rounded-2xl p-6 sm:p-8 text-left mb-6">
          <h3 class="font-serif font-bold text-xl text-gold-400 mb-4 flex items-center gap-2">
            <span>📝</span> Kesimpulan Materi
          </h3>
          <ul class="space-y-3 text-sm text-cream-100/70">
            {[
              'Puisi adalah karya sastra yang menggunakan bahasa padat, bermakna ganda, dan penuh keindahan bunyi.',
              'Unsur intrinsik puisi meliputi: tema, diksi, majas/gaya bahasa, citraan, nada, dan amanat.',
              'Para penyair besar Indonesia (Chairil Anwar, Sapardi Djoko Damono, dll.) telah memberi warna khas pada sastra nasional.',
              'Menganalisis puisi berarti membongkar lapisan-lapisan makna yang disembunyikan penyair dalam kata-kata.',
              'Menulis puisi adalah cara mengekspresikan diri yang otentik dan bermakna.',
            ].map((p, i) => (
              <li class="flex gap-3">
                <span class="text-gold-500 font-bold shrink-0">{i + 1}.</span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Quote final -->
        <div class="glass-dark rounded-2xl p-6 mb-8">
          <p class="font-serif italic text-xl text-gold-300 leading-relaxed">"Puisi bukan hanya tentang kata-kata yang indah, tetapi tentang kebenaran yang hanya bisa diungkapkan dengan cara yang paling indah."</p>
          <p class="text-cream-100/30 text-sm mt-3">— Sapardi Djoko Damono</p>
        </div>

        <div class="flex flex-wrap justify-center gap-3">
          <button 
            class="menu-nav-btn flex items-center gap-2 px-5 py-3 rounded-xl glass border border-navy-600 text-cream-100/70 text-sm font-medium hover:border-gold-500/30 hover:text-gold-400 transition-all"
            data-section="mission-map"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            Kembali ke Peta Misi
          </button>
          <button 
            class="menu-nav-btn flex items-center gap-2 px-5 py-3 rounded-xl glass border border-navy-600 text-cream-100/70 text-sm font-medium hover:border-gold-500/30 hover:text-gold-400 transition-all"
            data-section="glossary"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            Buka Glosarium
          </button>
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         SECTION: GLOSARIUM
         ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <section id="section-glossary" class="hidden min-h-screen px-4 py-12 max-w-4xl mx-auto">
      <div class="reveal">
        <button class="btn-back flex items-center gap-2 text-gold-400 hover:text-gold-300 transition-colors mb-8 text-sm" data-target="mission-map">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Kembali
        </button>

        <div class="ornament mb-4"><span class="text-gold-400 font-serif italic text-sm">Kamus Puisi</span></div>
        <h2 class="font-serif font-bold text-3xl text-gradient mb-2">Glosarium</h2>
        <p class="text-cream-100/40 text-sm mb-6">Istilah-istilah penting dalam dunia puisi</p>

        <!-- Search bar -->
        <div class="relative mb-6">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-cream-100/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input 
            id="glossary-search"
            type="text"
            placeholder="Cari istilah: majas, bait, diksi..."
            class="w-full pl-11 pr-4 py-3 rounded-xl poetry-textarea text-sm"
            style="resize: none; min-height: auto; line-height: 1.5; font-family: var(--font-sans);"
          />
        </div>

        <!-- Category filter -->
        <div class="flex flex-wrap gap-2 mb-6" id="glossary-filters">
          {['Semua', 'Majas', 'Unsur Intrinsik', 'Struktur', 'Citraan', 'Jenis Puisi', 'Gaya Bahasa', 'Analisis'].map(cat => (
            <button 
              class={`glossary-filter-btn px-3 py-1.5 rounded-full text-xs font-medium transition-all border ${cat === 'Semua' ? 'bg-gold-500/20 border-gold-500/40 text-gold-300' : 'glass border-navy-600 text-cream-100/50 hover:border-gold-500/30 hover:text-gold-400'}`}
              data-cat={cat}
            >
              {cat}
            </button>
          ))}
        </div>

        <!-- Glossary cards grid -->
        <div id="glossary-grid" class="grid sm:grid-cols-2 gap-3">
          {glossary.map(item => (
            <div 
              class={`glossary-item glass rounded-xl p-4 card-hover`}
              data-term={item.term.toLowerCase()}
              data-def={item.definition.toLowerCase()}
              data-cat={item.category}
            >
              <div class="flex items-start justify-between gap-2 mb-2">
                <h4 class="font-serif font-bold text-gold-300 text-base leading-tight">{item.term}</h4>
                <span class="shrink-0 px-2 py-0.5 rounded-full bg-navy-700 text-cream-100/40 text-xs">{item.category}</span>
              </div>
              <p class="text-cream-100/60 text-sm leading-relaxed">{item.definition}</p>
            </div>
          ))}
        </div>

        <div id="glossary-empty" class="hidden text-center py-12">
